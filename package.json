{
  "name": "flux-root",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "lint": "bunx biome check .",
    "format": "bunx biome check --write .",
    "db:migrate": "cd backend && bun run db:migrate",
    "db:seed": "cd backend && bun run db:seed",
    "test:frontend": "cd frontend && bun run test",
    "test:e2e": "bunx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "bunx playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "bunx playwright test --config=e2e/playwright.config.ts --headed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.52.0"
  }
}
